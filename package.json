{
  "name": "devpulse",
  "main": "expo-router/entry",
  "version": "1.0.4",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
