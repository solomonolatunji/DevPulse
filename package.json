    "build:android": "eas build --platform android",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:dev:android": "eas build --platform android --profile development",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "preview:android": "eas build --profile preview --platform android",
    "preview:ios": "eas build --profile preview --platform ios",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "tsc --noEmit",
    "test": "jest"
  },
